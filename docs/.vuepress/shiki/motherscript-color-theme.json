{
    "$schema": "vscode://schemas/color-theme",
    "name": "MotherScript Dark Theme",
    "type": "dark",
    "semanticHighlighting": false,
    "colors": {
        "editor.background": "#0D0706",
        "editor.foreground": "#F2F0EC"
    },
    "tokenColors": [
        {
            "scope": "comment.line.semicolon.motherscript, comment.line.number-sign.motherscript",
            "settings": {
                "foreground": "#4CAF50",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "entity.name.section.motherscript",
            "settings": {
                "foreground": "#C20000",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "punctuation.definition.section.begin.motherscript, punctuation.definition.section.end.motherscript, keyword.operator.pipe.motherscript, keyword.operator.assignment.motherscript, punctuation.terminator.semicolon.motherscript",
            "settings": {
                "foreground": "#6F6A68"
            }
        },
        {
            "scope": "entity.name.function.motherscript, variable.other.assignment-key.motherscript",
            "settings": {
                "foreground": "#C20000",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "entity.name.namespace.motherscript",
            "settings": {
                "foreground": "#F2F0EC",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "punctuation.separator.command.motherscript",
            "settings": {
                "foreground": "#8B8683"
            }
        },
        {
            "scope": "support.function.action.motherscript, support.function.motherscript",
            "settings": {
                "foreground": "#F2F0EC",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "variable.other.remote-target.motherscript",
            "settings": {
                "foreground": "#5DA9FF",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "keyword.other.flag.motherscript",
            "settings": {
                "foreground": "#B59336"
            }
        },
        {
            "scope": "entity.other.attribute-name.id.motherscript, variable.language.this.motherscript",
            "settings": {
                "foreground": "#B59336"
            }
        },
        {
            "scope": "string.quoted.double, string.quoted.single",
            "settings": {
                "foreground": "#A6A6A6",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "string.unquoted.motherscript",
            "settings": {
                "foreground": "#A6A6A6"
            }
        },
        {
            "scope": "constant.numeric, constant.language.boolean, constant.language.boolean.motherscript",
            "settings": {
                "foreground": "#B59336"
            }
        }
    ]
}