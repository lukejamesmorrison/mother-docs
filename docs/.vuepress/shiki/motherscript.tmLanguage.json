{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MotherScript",
  "scopeName": "source.motherscript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#sectionHeader"
    },
    {
      "include": "#header"
    },
    {
      "include": "#pipeLine"
    },
    {
      "include": "#singleLineCommand"
    },
    {
      "include": "#settingLine"
    },
    {
      "include": "#commandLine"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.motherscript",
          "match": "^\\s*;.*$"
        },
        {
          "name": "comment.line.number-sign.motherscript",
          "match": "^\\s*#.*$"
        }
      ]
    },
    "sectionHeader": {
      "patterns": [
        {
          "name": "meta.section.motherscript",
          "match": "^\\s*(\\[)([^\\]]+)(\\])\\s*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.section.begin.motherscript"
            },
            "2": {
              "name": "entity.name.section.motherscript"
            },
            "3": {
              "name": "punctuation.definition.section.end.motherscript"
            }
          }
        }
      ]
    },
    "header": {
      "patterns": [
        {
          "name": "meta.header.motherscript",
          "match": "^\\s*((?:\"[^\"]+\"|[A-Za-z_][A-Za-z0-9_-]*)(?:\\.(?:\"[^\"]+\"|[A-Za-z_][A-Za-z0-9_-]*))*)\\s*(=)\\s*$",
          "captures": {
            "1": {
              "name": "entity.name.function.motherscript"
            },
            "2": {
              "name": "keyword.operator.assignment.motherscript"
            }
          }
        }
      ]
    },
    "pipeLine": {
      "patterns": [
        {
          "begin": "^(\\s*)(\\|)\\s*(@[A-Za-z0-9_:-]+\\s+)?([A-Za-z][A-Za-z0-9_-]*)(/)([A-Za-z][A-Za-z0-9_-]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.leading.motherscript"
            },
            "2": {
              "name": "keyword.operator.pipe.motherscript"
            },
            "3": {
              "name": "variable.other.remote-target.motherscript"
            },
            "4": {
              "name": "entity.name.namespace.motherscript"
            },
            "5": {
              "name": "punctuation.separator.command.motherscript"
            },
            "6": {
              "name": "support.function.action.motherscript"
            }
          },
          "end": "$",
          "name": "meta.pipeline.motherscript",
          "patterns": [
            {
              "include": "#chainedCommand"
            },
            {
              "include": "#flags"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#hashIds"
            },
            {
              "include": "#commandSegment"
            },
            {
              "include": "#bareString"
            },
            {
              "include": "#semicolon"
            }
          ]
        }
      ]
    },
    "singleLineCommand": {
      "patterns": [
        {
          "begin": "^\\s*((?:\"[^\"]+\"|[A-Za-z_][A-Za-z0-9_-]*)(?:\\.(?:\"[^\"]+\"|[A-Za-z_][A-Za-z0-9_-]*))*)\\s*(=)\\s*(@[A-Za-z0-9_:-]+\\s+)?([A-Za-z][A-Za-z0-9_-]*)(/)([A-Za-z][A-Za-z0-9_-]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.motherscript"
            },
            "2": {
              "name": "keyword.operator.assignment.motherscript"
            },
            "3": {
              "name": "variable.other.remote-target.motherscript"
            },
            "4": {
              "name": "entity.name.namespace.motherscript"
            },
            "5": {
              "name": "punctuation.separator.command.motherscript"
            },
            "6": {
              "name": "support.function.action.motherscript"
            }
          },
          "end": "$",
          "name": "meta.singleline.motherscript",
          "patterns": [
            {
              "include": "#chainedCommand"
            },
            {
              "include": "#flags"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#hashIds"
            },
            {
              "include": "#commandSegment"
            },
            {
              "include": "#bareString"
            },
            {
              "include": "#semicolon"
            }
          ]
        }
      ]
    },
    "settingLine": {
      "patterns": [
        {
          "begin": "^\\s*((?:\"[^\"]+\"|[A-Za-z_][A-Za-z0-9_-]*)(?:\\.(?:\"[^\"]+\"|[A-Za-z_][A-Za-z0-9_-]*))*)\\s*(=)\\s*",
          "beginCaptures": {
            "1": {
              "name": "variable.other.assignment-key.motherscript"
            },
            "2": {
              "name": "keyword.operator.assignment.motherscript"
            }
          },
          "end": "$",
          "name": "meta.setting.motherscript",
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#hashIds"
            },
            {
              "include": "#inlineHashComment"
            },
            {
              "include": "#bareString"
            }
          ]
        }
      ]
    },
    "commandLine": {
      "patterns": [
        {
          "begin": "^(\\s*)(@[A-Za-z0-9_:-]+\\s+)?([A-Za-z][A-Za-z0-9_-]*)(/)([A-Za-z][A-Za-z0-9_-]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.leading.motherscript"
            },
            "2": {
              "name": "variable.other.remote-target.motherscript"
            },
            "3": {
              "name": "entity.name.namespace.motherscript"
            },
            "4": {
              "name": "punctuation.separator.command.motherscript"
            },
            "5": {
              "name": "support.function.action.motherscript"
            }
          },
          "end": "$",
          "name": "meta.commandline.motherscript",
          "patterns": [
            {
              "include": "#chainedCommand"
            },
            {
              "include": "#flags"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#hashIds"
            },
            {
              "include": "#commandSegment"
            },
            {
              "include": "#bareString"
            },
            {
              "include": "#semicolon"
            }
          ]
        },
        {
          "include": "#semicolon"
        }
      ]
    }
    ,
    "chainedCommand": {
      "patterns": [
        {
          "match": "(;)(?:\\s*)(@[A-Za-z0-9_:-]+\\s+)?([A-Za-z][A-Za-z0-9_-]*)(/)([A-Za-z][A-Za-z0-9_-]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.terminator.semicolon.motherscript"
            },
            "2": {
              "name": "variable.other.remote-target.motherscript"
            },
            "3": {
              "name": "entity.name.namespace.motherscript"
            },
            "4": {
              "name": "punctuation.separator.command.motherscript"
            },
            "5": {
              "name": "support.function.action.motherscript"
            }
          }
        }
      ]
    },
    "commandSegment": {
      "patterns": [
        {
          "match": "(?x)\\b([A-Za-z][A-Za-z0-9_-]*)(/)([A-Za-z][A-Za-z0-9_-]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.namespace.motherscript"
            },
            "2": {
              "name": "punctuation.separator.command.motherscript"
            },
            "3": {
              "name": "support.function.action.motherscript"
            }
          }
        },
        {
          "name": "variable.language.this.motherscript",
          "match": "\\bthis\\b"
        }
      ]
    },
    "flags": {
      "patterns": [
        {
          "name": "keyword.other.flag.motherscript",
          "match": "--[A-Za-z0-9_-]+(?:=(?:[^\\s\"';]+|\"[^\"]*\"|'[^']*'))?"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.motherscript",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.motherscript",
          "match": "(?<![#A-Za-z0-9_])[-+]?[0-9]+\\.[0-9]+"
        },
        {
          "name": "constant.numeric.integer.motherscript",
          "match": "(?<![#A-Za-z0-9_])[-+]?[0-9]+(?![A-Za-z0-9_])"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.motherscript",
          "match": "\"[^\"]*\""
        }
      ]
    },
    "hashIds": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.id.motherscript",
          "match": "#[A-Za-z0-9_-]+(?::[0-9]+)?"
        }
      ]
    },
    "inlineHashComment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.motherscript",
          "match": "\\s+#.*$"
        }
      ]
    },
    "bareString": {
      "patterns": [
        {
          "name": "string.unquoted.motherscript",
          "match": "\\b[A-Za-z][A-Za-z0-9_-]*\\b"
        }
      ]
    },
    "semicolon": {
      "patterns": [
        {
          "name": "punctuation.terminator.semicolon.motherscript",
          "match": ";"
        }
      ]
    }
  }
}